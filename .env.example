# ===========================================
# AI Chat – floating chatbot
# ===========================================
# Copy to .env. Never commit .env or real keys.

# --- Option A: Use your backend (recommended – key stays on server) ---
# Run: node server/server.js (from project root). Server uses HUGGINGFACE_API_KEY below.
VITE_CHAT_API_URL=http://localhost:5000

# Hugging Face key for the SERVER (server/server.js). Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# --- Option B: Call APIs from frontend (key in .env, not for production) ---
# VITE_HUGGINGFACE_API_KEY=

# Google Gemini (FREE) - https://aistudio.google.com/app/apikey
# VITE_GEMINI_API_KEY=

# Groq (FREE) - https://console.groq.com/keys
# VITE_GROQ_API_KEY=

# OpenAI (paid) - https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=
